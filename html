    </section>

    <section id="contact">
        <div class="container">
            <h2 class="section-title">Connect With Me</h2>
            <div class="contact-card">
                <div class="social-links">
                    <a href="https://github.com/x-Anuhas" class="social-link" target="_blank"><i class="fab fa-github"></i> GitHub</a>
                    <a href="https://www.instagram.com/x_anuhas" class="social-link" target="_blank"><i class="fab fa-instagram"></i> Instagram</a>
                    <a href="mailto:xanuhas@gmail.com" class="social-link"><i class="fas fa-envelope"></i> Email</a>
                </div>
                <p style="text-align: center; margin-top: 32px; color: #475569;">Open to collaboration, Linux discussions, and internship opportunities. Feel free to reach out!</p>
            </div>
        </div>
    </section>
</main>

<footer>
    <p>© 2025 Anuhas Abesinpathirana. Built with HTML/CSS.</p>
